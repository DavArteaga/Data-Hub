# DataCore Hub – environment variables
# Copy this file to .env and adjust as needed

# Application
APP_NAME="DataCore Hub API"
APP_VERSION="0.1.0"
DEBUG=true

# Database (SQLite by default – path relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./data/datahub.db

# CORS – comma-separated list of allowed origins (* = all)
CORS_ORIGINS=*

# Scraper timeouts (seconds)
SCRAPER_TIMEOUT=30
